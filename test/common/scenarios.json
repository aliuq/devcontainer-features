{
  "zsh": {
    "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
    "features": {
      "ghcr.io/devcontainers/features/common-utils:2": {
        "installZsh": true,
        "configureZshAsDefaultShell": true
      },
      "common": {
        "installStarship": true,
        "installYazi": true,
        "installHttpie": true,
        "pnpmCompletion": true
      }
    }
  },
  "repeated": {
    "image": "ghcr.io/aliuq/devcontainer:base",
    "features": {
      "common": {
        "installStarship": true,
        "installYazi": true,
        "installHttpie": true,
        "pnpmCompletion": true
      }
    }
  },
  "bash": {
    "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
    "features": {
      "ghcr.io/devcontainers/features/common-utils:2": {
        "installZsh": true
      },
      "common": {
        "defaultShell": "bash",
        "installStarship": true,
        "installYazi": true,
        "installHttpie": true,
        "pnpmCompletion": true
      }
    }
  },
  "alpine": {
    "image": "mcr.microsoft.com/devcontainers/base:alpine",
    "features": {
      "common": {
        "installStarship": true,
        "installYazi": true,
        "installHttpie": true,
        "pnpmCompletion": true
      }
    }
  },
  "minimal": {
    "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
    "features": {
      "ghcr.io/devcontainers/features/common-utils:2": {
        "installZsh": true,
        "configureZshAsDefaultShell": true
      },
      "common": {}
    }
  },
  "mise-packages": {
    "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
    "features": {
      "ghcr.io/devcontainers/features/common-utils:2": {
        "installZsh": true,
        "configureZshAsDefaultShell": true
      },
      "common": {
        "misePackages": "node@lts"
      }
    }
  },
  "zsh-plugins": {
    "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
    "features": {
      "ghcr.io/devcontainers/features/common-utils:2": {
        "installZsh": true,
        "configureZshAsDefaultShell": true,
        "installOhMyZsh": true
      },
      "common": {
        "zshPlugins": "git,docker"
      }
    }
  }
}
