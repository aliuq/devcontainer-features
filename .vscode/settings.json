{
  "cSpell.ignorePaths": [
    "devcontainer.json",
    "devcontainer-feature.json",
    "*.sh"
  ],
  "markdownlint.config": {
    "first-line-h1": false,
    "no-emphasis-as-heading": false
  },
  "cSpell.words": [
    "direnv",
    "pyenv",
    "Yazi"
  ],
  "github.copilot.chat.commitMessageGeneration.instructions": [
    {
      "file": ".github/commit-instructions.md"
    }
  ]
}
